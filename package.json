{
  "name": "titrate",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "test:sdk": "npm run test -w packages/sdk",
    "test:contracts": "npm run test -w packages/contracts",
    "coverage:sdk": "cd packages/sdk && npx vitest run --coverage",
    "coverage:contracts": "cd packages/contracts && forge coverage"
  },
  "resolutions": {
    "vite": "^7"
  },
  "packageManager": "yarn@4.14.0+sha512.31053dd4c730c75e8665ad00bbfe07a7bed08aef54c5edfd8d484463680180b1c87035a61b9e15ff2cad310a329176cac433009e2d402ac69d1386f9445d7ccb"
}
